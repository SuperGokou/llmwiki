# 复制为 .env（勿提交）。本地开发默认连本机 Ollama；Render 使用 Dashboard 环境变量。

# ========== 本地：本机 Ollama（默认）==========
OLLAMA_API_URL=http://127.0.0.1:11434/api/generate
# 若远端 Ollama 网关要鉴权：
# API_KEY=...

# ========== Ollama 官方云（与 SDK Client(host='https://ollama.com', Bearer) 一致）==========
# 设置后即走云端 Chat API（不要在同一环境里再配 LLM_BACKEND=openai，除非你故意要用 Groq）。
# OLLAMA_HOST=https://ollama.com
# OLLAMA_API_KEY=

# ========== Groq / OpenAI 兼容（可选）==========
# LLM_BACKEND=openai
# OPENAI_API_BASE=https://api.groq.com/openai/v1
# OPENAI_API_KEY=
# （别名）GROQ_API_KEY=

# ========== 模型名（须与当前选用的后端一致）==========
KNOWLEDGE_MODEL=gemma4:latest
OCR_MODEL=deepseek-ocr:latest
CHAT_MODEL=llama3.2:latest
