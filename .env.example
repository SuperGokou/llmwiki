# --- Local: Ollama（默认）---
OLLAMA_API_URL=http://127.0.0.1:11434/api/generate
# 远端 Ollama 网关如需鉴权可配：
# API_KEY=...

# --- Render / 云端：OpenAI 兼容 API（Groq、OpenAI、OpenRouter 等）---
# 设为 openai 时忽略本机 Ollama，改为走 OPENAI_*（见下）。
# LLM_BACKEND=openai
# OPENAI_API_BASE=https://api.groq.com/openai/v1
# OPENAI_API_KEY=你的密钥勿提交仓库

# Model routing（名称须与所选提供商一致）
KNOWLEDGE_MODEL=gemma4:latest
OCR_MODEL=deepseek-ocr:latest
CHAT_MODEL=llama3.2:latest

# Groq 示例（需同步把上面三个模型改成 Groq 支持的 id，例如 llama-3.3-70b-versatile）
# LLM_BACKEND=openai
# OPENAI_API_BASE=https://api.groq.com/openai/v1
# KNOWLEDGE_MODEL=llama-3.3-70b-versatile
# OCR_MODEL=llama-3.3-70b-versatile
# CHAT_MODEL=llama-3.3-70b-versatile
